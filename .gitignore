# Raw sequencing data
data/*.fastq
data/*.fq
data/*.fastq.gz
data/*.fq.gz

# Reference assets and generated indexes — only README and .gitkeep are tracked
reference/*
!reference/.gitkeep
!reference/README.md
# Ignore all subdirectories (genome FASTA, GTF, STAR index — download/generate locally)
reference/**/

# Workflow outputs and runtime state
results/*
!results/.gitkeep
logs/*
!logs/.gitkeep
.snakemake/

# Alignment and intermediate files
*.bam
*.bai
*.sam
*.cram
*.crai
*.tmp
*.temp

# System files
.DS_Store
Thumbs.db

# Python / environments
__pycache__/
*.pyc
.env

# Keep empty directory structure
!.gitkeep
